# Virtual environments
venv/
.venv/
env/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Environment variables / secrets
.env
.env.local
*.pem
*.key
.pypirc

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/

# Python version manager
.python-version

# Editable install metadata
src/*.egg-info/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# VS Code workspace settings (optional — see notes below)
.vscode/

# VS Code workspace file (machine-specific)
*.code-workspace

# Logs
*.log
logs/

# Database files (if you store local test DBs)
*.db
*.sqlite
*.sqlite3

# Node modules (for when you do front-end work)
node_modules/
npm-debug.log

# IDE caches (beyond VS Code)
.idea/
*.swp
*.swo

# AWS CLI local config (credentials handled by .env, but config cache)
.aws/

# Local data / exports (useful for BI work)
data/local/
exports/
*.csv.local