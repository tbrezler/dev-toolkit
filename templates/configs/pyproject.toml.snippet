[tool.ruff]
line-length = 120
target-version = "py312"

[tool.ruff.lint]
select = ["F", "E", "W", "B", "BLE", "I", "UP", "A", "RUF", "T10"]
ignore = [
    "E501",   # line length (handled by ruff format)
]

[tool.mypy]
python_version = "3.12"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = false